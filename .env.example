# Docker Compose — copy to .env at the project root
# Used by docker-compose.yml and docker-compose.prod.yml

# Backend (host = Docker service name "postgres", not localhost)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/monitoringsite?schema=public

# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=monitoringsite

# Backend port inside Docker (must match nginx proxy_pass in nginx/nginx.conf)
PORT=3000

# Inlined at frontend image build — browser reaches API via Nginx on the host
VITE_API_URL=http://localhost:8081/api
